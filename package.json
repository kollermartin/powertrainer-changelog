{
    "name": "@powertrainer/changelog",
    "version": "1.4.0",
    "description": "Single source of truth for the PowerTrainer changelog — shared data + a simple React component across fe-web (React 18) and fe-landing (React 19).",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./changelog.css": "./dist/changelog.css"
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "**/*.css"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepare": "npm run build"
    },
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@testing-library/react": "^16.1.0",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tsup": "^8.3.5",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    },
    "license": "UNLICENSED",
    "private": false
}
